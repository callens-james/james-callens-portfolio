{
  "name": "weather-dashboard",
  "version": "0.1.0",
  "description": "Portable desktop weather dashboard for outdoor planning",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"node server.js\" \"wait-on http://localhost:3210 && electron .\"",
    "dev": "npm run start",
    "pack:win": "electron-builder --win portable"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.james.weatherdashboard",
    "productName": "Weather Dashboard",
    "files": [
      "electron/**/*",
      "public/**/*",
      "assets/**/*",
      "server.js",
      "package.json"
    ],
    "win": {
      "target": ["portable"],
      "icon": "assets/weather-icon.ico"
    }
  }
}
