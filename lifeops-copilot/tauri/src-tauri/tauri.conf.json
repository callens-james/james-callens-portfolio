{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LifeOps Copilot",
  "version": "0.3.0",
  "identifier": "ai.lifeops.copilot",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "LifeOps Copilot",
        "width": 1180,
        "height": 700,
        "minWidth": 1024,
        "minHeight": 620,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png"
    ]
  }
}